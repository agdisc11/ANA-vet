# Copia este archivo a `.env` y rellena los valores.
# El .env real NUNCA se versiona (está en .gitignore).

# ── Base de datos ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=anavet
DB_PASS=cambia-esta-contrasena
DB_NAME=clinica_veterinaria

# ── Seguridad ─────────────────────────────────────────────────
# OBLIGATORIA: el servidor se niega a arrancar sin ella.
# Genera una nueva con:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# ── Servidor ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# Orígenes permitidos por CORS, separados por comas.
# Si el frontend se sirve desde el MISMO dominio que la API (nginx con
# reverse-proxy de /api), esta variable NO hace falta: no hay petición
# cross-origin que permitir.
# CORS_ORIGIN=https://mi-dominio.com
